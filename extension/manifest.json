{
  "manifest_version": 3,
  "name": "Vorder-Colick",
  "version": "0.1.0",
  "description": "공공사이트 업무 자동화 크롬 익스텐션",
  "permissions": ["debugger", "activeTab", "scripting", "storage", "alarms"],
  "host_permissions": [
    "https://www.gov.kr/*",
    "https://*.gov.kr/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.gov.kr/*", "https://*.gov.kr/*"],
      "js": ["content/pip-panel.js", "content/collector.js"],
      "css": ["styles/pip-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles/*.css"],
      "matches": ["https://www.gov.kr/*", "https://*.gov.kr/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
