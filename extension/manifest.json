{
  "manifest_version": 3,
  "name": "Vorder-Colick",
  "version": "0.1.0",
  "description": "공공사이트 업무 자동화 크롬 익스텐션",
  "permissions": ["debugger", "activeTab", "scripting", "storage", "alarms"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Vorder 활성화"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/*.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
